# dependencies (each app also has its own more specific entry)
node_modules
.pnpm-store

# OS
.DS_Store

# editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea

# env files (never commit real secrets; per-app .env.example is fine)
.env
.env.local
.env.*.local

# Vercel CLI local project link (each app has its own more specific entry; a
# root-level .vercel/project.json is only ever a temporary deploy-workaround
# link and should never be tracked — see apps/admin's Root Directory note)
.vercel
